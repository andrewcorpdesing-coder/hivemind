{
  "name": "hiveclaude",
  "version": "0.1.2",
  "type": "module",
  "description": "Coordinate multiple Claude Code agents working in parallel on the same codebase",
  "keywords": [
    "claude",
    "ai",
    "agents",
    "mcp",
    "multi-agent",
    "claude-code"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/andrewcorpdesing-coder/hiveclaude"
  },
  "bin": {
    "hiveclaude": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && node -e \"const{cpSync,mkdirSync,copyFileSync}=require('fs');mkdirSync('dist/broker',{recursive:true});cpSync('../broker/dist','dist/broker',{recursive:true});copyFileSync('../../README.md','README.md');\"",
    "test": "node --test dist/tests/**/*.test.js"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "chalk": "^5.3.0",
    "@inquirer/prompts": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  }
}
